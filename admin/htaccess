# ─── Protection dossier admin ───────────────────────────────────────────────
# Interdire l'accès direct aux fichiers de config et logs

<FilesMatch "^(config|setup)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<FilesMatch "^setup\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Interdire le listing des répertoires
Options -Indexes

# Forcer HTTPS (décommentez en production)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Headers de sécurité
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Cache: ne pas mettre en cache les pages admin
<FilesMatch "\.(php)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </IfModule>
</FilesMatch>
